# ===========================================
# CODEEX AI UI — Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!

# ===========================================
# BACKEND SERVER URL (REQUIRED)
# ===========================================
# Local dev: http://localhost:8080
# Production: https://your-backend.onrender.com
# Vercel uses SERVER_URL on the server side. The browser should call same-origin
# Next.js API routes instead of talking to Render directly.
NEXT_PUBLIC_SERVER_URL=https://your-backend.onrender.com
SERVER_URL=http://localhost:8080

# ===========================================
# APP URL
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# FIREBASE (REQUIRED)
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ===========================================
# AI API KEYS (used by Next.js API routes)
# ===========================================
GROQ_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=
CEREBRAS_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=

# ===========================================
# SUPABASE
# ===========================================
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ===========================================
# CLOUDFLARE AI
# ===========================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=

# ===========================================
# UPSTASH VECTOR
# ===========================================
UPSTASH_VECTOR_URL=
UPSTASH_VECTOR_TOKEN=

# ===========================================
# EMAIL
# ===========================================
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_WELCOME_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_USER_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ===========================================
# PUBLIC KEYS
# ===========================================
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# ===========================================
# SHARED APP SECRET
# ===========================================
# Must match the backend SOHAM_API_KEY value.
SOHAM_API_KEY=soham-secret-key-2025

# ===========================================
# DATA APIs
# ===========================================
GNEWS_API_KEY=
CRICAPI_KEY=
ALPHA_VANTAGE_API_KEY=

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_SAFETY_GUARD=true
ENABLE_MEMORY_SYSTEM=false
