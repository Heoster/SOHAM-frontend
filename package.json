{
  "name": "codeex-ai-ui",
  "version": "2.0.0",
  "description": "CodeEx AI — Complete frontend + backend UI app",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prod": "npm run typecheck && npm run build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:netlify": "node scripts/netlify-build.js",
    "verify:deployment": "node scripts/verify-deployment.js",
    "verify-env": "node scripts/verify-env.js",
    "check-deploy": "node scripts/check-deployment-ready.js",
    "test:api": "node scripts/test-api-routes.js",
    "test:tts": "node scripts/test-groq-tts.js",
    "test:tts:quick": "node scripts/test-groq-tts.js --quick --save",
    "clear-cache": "pwsh -File scripts/clear-cache.ps1",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "install:all": "npm install && npm run server:install"
  },
